{
  "name": "vibeagentgo",
  "version": "2607.5.8",
  "description": "vibeAgentGo — Fully client-side AI agent PWA with memory, skills, and Web Worker code sandbox",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p web/tsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint web/src --ext .ts,.js",
    "lint:fix": "eslint web/src --ext .ts,.js --fix",
    "format": "prettier --write \"web/src/**/*.{ts,js,json,md}\" \"*.md\""
  },
  "keywords": [
    "ai-agent",
    "agent",
    "pwa",
    "mobile",
    "ai",
    "typescript",
    "data-sovereignty"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "dompurify": "^3.2.0",
    "jszip": "^3.10.1",
    "marked": "^15.0.0",
    "pdfjs-dist": "^6.1.200",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.0.0",
    "@types/pdfjs-dist": "^2.10.377",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.9.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^3.0.0"
  }
}
